#let data = range(1, 6).zip(d1, d2, d3, d4).flatten().map(v => [#v])

#table(
  columns: (1.5fr, 1fr, 1fr, 1fr, 1fr),
  table.header(
    table.cell(rowspan: 2)[Номер наблюдения],
